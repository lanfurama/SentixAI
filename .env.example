# Google Cloud / Vertex AI Configuration
# Required for AI analysis functionality
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=

# Optional: Service Account Path (if using service account JSON file)
VERTEX_AI_SERVICE_ACCOUNT_PATH=
VERTEX_AI_ENDPOINT_ID=
VERTEX_AI_API_KEY=

# Optional: Vertex AI Model (defaults to gemini-1.5-flash)
VERTEX_AI_MODEL=

# Server Port (defaults to 3001)
# PORT=3001
